<Window x:Class="Clicky.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:companion="clr-namespace:Clicky.Companion;assembly=Clicky.Companion"
        xmlns:local="clr-namespace:Clicky.App"
        Title="Settings"
        Width="480" Height="640"
        MinWidth="400" MinHeight="540"
        WindowStartupLocation="CenterScreen"
        Background="#1C1C1E"
        Foreground="#F5F5F7"
        ResizeMode="CanResize">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBackground" Color="#1C1C1E" />
        <SolidColorBrush x:Key="CardBackground" Color="#262628" />
        <SolidColorBrush x:Key="BorderSubtle" Color="#2C2C2E" />
        <SolidColorBrush x:Key="TextPrimary" Color="#F5F5F7" />
        <SolidColorBrush x:Key="TextSecondary" Color="#C7C7CC" />
        <SolidColorBrush x:Key="TextTertiary" Color="#8E8E93" />
        <SolidColorBrush x:Key="Success" Color="#34C759" />
        <SolidColorBrush x:Key="Failure" Color="#FF453A" />
        <SolidColorBrush x:Key="Accent" Color="#3B82F6" />
        <SolidColorBrush x:Key="InputBackground" Color="#38383A" />
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!-- Converts non-null to Visible, null to Collapsed -->
        <local:NullToVisibilityConverter x:Key="NullToCollapsed" />

        <!-- Rounded button style -->
        <Style x:Key="AccentButton" TargetType="Button">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="Background" Value="{StaticResource Accent}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.4" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Foreground" Value="{StaticResource TextTertiary}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TestButton" TargetType="Button">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
            <Setter Property="Background" Value="{StaticResource CardBackground}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderSubtle}" />
            <Setter Property="BorderThickness" Value="0.5" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="MinWidth" Value="52" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LinkButton" TargetType="Button">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{StaticResource Accent}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <TextBlock Text="{TemplateBinding Content}"
                                   Foreground="{TemplateBinding Foreground}"
                                   FontSize="{TemplateBinding FontSize}"
                                   TextDecorations="Underline" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ComboBox dark style -->
        <Style x:Key="DarkComboBox" TargetType="ComboBox">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="Background" Value="{StaticResource InputBackground}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderSubtle}" />
            <Setter Property="BorderThickness" Value="0.5" />
            <Setter Property="Padding" Value="10,7" />
        </Style>

        <!-- TextBox dark style -->
        <Style x:Key="DarkTextBox" TargetType="TextBox">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="Background" Value="{StaticResource InputBackground}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderSubtle}" />
            <Setter Property="BorderThickness" Value="0.5" />
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="CaretBrush" Value="{StaticResource TextPrimary}" />
        </Style>

        <!-- PasswordBox dark style -->
        <Style x:Key="DarkPasswordBox" TargetType="PasswordBox">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="Background" Value="{StaticResource InputBackground}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderSubtle}" />
            <Setter Property="BorderThickness" Value="0.5" />
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="CaretBrush" Value="{StaticResource TextPrimary}" />
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="24,20,24,20">

            <!-- Header -->
            <TextBlock x:Name="HeaderText"
                       Text="Settings"
                       FontSize="20"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimary}"
                       Margin="0,0,0,20" />

            <!-- LLM Provider -->
            <TextBlock Text="LLM SERVICE"
                       FontSize="10" FontWeight="SemiBold"
                       Foreground="{StaticResource TextTertiary}"
                       Margin="0,0,0,6" />

            <ComboBox x:Name="ProviderCombo"
                      Style="{StaticResource DarkComboBox}"
                      ItemsSource="{Binding Providers}"
                      DisplayMemberPath="Display"
                      SelectedValuePath="Value"
                      SelectedValue="{Binding SelectedProvider, Mode=TwoWay}"
                      Margin="0,0,0,12" />

            <!-- LLM Model -->
            <TextBlock Text="MODEL"
                       FontSize="10" FontWeight="SemiBold"
                       Foreground="{StaticResource TextTertiary}"
                       Margin="0,0,0,6" />

            <ComboBox x:Name="ModelCombo"
                      Style="{StaticResource DarkComboBox}"
                      ItemsSource="{Binding AvailableModels}"
                      DisplayMemberPath="Display"
                      SelectedValuePath="Value"
                      SelectedValue="{Binding SelectedModel, Mode=TwoWay}"
                      Margin="0,0,0,20" />

            <!-- Separator -->
            <Border Height="0.5" Background="{StaticResource BorderSubtle}" Margin="0,0,0,20" />

            <!-- API KEYS header -->
            <TextBlock Text="API KEYS"
                       FontSize="10" FontWeight="SemiBold"
                       Foreground="{StaticResource TextTertiary}"
                       Margin="0,0,0,12" />

            <!-- Anthropic API Key -->
            <Grid Margin="0,0,0,4">
                <TextBlock Text="Anthropic"
                           FontSize="13" FontWeight="Medium"
                           Foreground="{StaticResource TextSecondary}"
                           VerticalAlignment="Center" />
                <Button Content="Get key &#x2192;"
                        Style="{StaticResource LinkButton}"
                        HorizontalAlignment="Right"
                        Click="AnthropicLink_Click" />
            </Grid>
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <!-- Password field (visible when key is NOT saved as placeholder) -->
                <PasswordBox x:Name="AnthropicKeyBox"
                             Grid.Column="0"
                             Style="{StaticResource DarkPasswordBox}"
                             PasswordChanged="AnthropicKeyBox_PasswordChanged"
                             Margin="0,0,8,0" />
                <!-- Saved placeholder (visible when key IS saved) -->
                <TextBox x:Name="AnthropicSavedPlaceholder"
                         Grid.Column="0"
                         Style="{StaticResource DarkTextBox}"
                         Text="&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;"
                         IsReadOnly="True"
                         Margin="0,0,8,0"
                         Visibility="Collapsed" />
                <Button x:Name="AnthropicChangeBtn"
                        Grid.Column="1"
                        Content="Change"
                        Style="{StaticResource TestButton}"
                        Click="AnthropicChange_Click"
                        Visibility="Collapsed"
                        Margin="0,0,8,0" />
                <Button x:Name="AnthropicTestBtn"
                        Grid.Column="2"
                        Content="Test"
                        Style="{StaticResource TestButton}"
                        Click="AnthropicTest_Click" />
            </Grid>

            <!-- Anthropic key error -->
            <TextBlock Text="{Binding AnthropicKeyError}"
                       FontSize="11" Foreground="{StaticResource Failure}"
                       Margin="0,0,0,4"
                       Visibility="{Binding AnthropicKeyError, Converter={StaticResource NullToCollapsed}}" />

            <!-- z.ai API Key -->
            <Grid Margin="0,0,0,4">
                <TextBlock Text="z.ai"
                           FontSize="13" FontWeight="Medium"
                           Foreground="{StaticResource TextSecondary}"
                           VerticalAlignment="Center" />
                <Button Content="Get key &#x2192;"
                        Style="{StaticResource LinkButton}"
                        HorizontalAlignment="Right"
                        Click="ZaiLink_Click" />
            </Grid>
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <PasswordBox x:Name="ZaiKeyBox"
                             Grid.Column="0"
                             Style="{StaticResource DarkPasswordBox}"
                             PasswordChanged="ZaiKeyBox_PasswordChanged"
                             Margin="0,0,8,0" />
                <TextBox x:Name="ZaiSavedPlaceholder"
                         Grid.Column="0"
                         Style="{StaticResource DarkTextBox}"
                         Text="&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;"
                         IsReadOnly="True"
                         Margin="0,0,8,0"
                         Visibility="Collapsed" />
                <Button x:Name="ZaiChangeBtn"
                        Grid.Column="1"
                        Content="Change"
                        Style="{StaticResource TestButton}"
                        Click="ZaiChange_Click"
                        Visibility="Collapsed"
                        Margin="0,0,8,0" />
                <Button x:Name="ZaiTestBtn"
                        Grid.Column="2"
                        Content="Test"
                        Style="{StaticResource TestButton}"
                        Click="ZaiTest_Click" />
            </Grid>

            <!-- z.ai key error -->
            <TextBlock Text="{Binding ZaiKeyError}"
                       FontSize="11" Foreground="{StaticResource Failure}"
                       Margin="0,0,0,4"
                       Visibility="{Binding ZaiKeyError, Converter={StaticResource NullToCollapsed}}" />

            <!-- AssemblyAI API Key -->
            <Grid Margin="0,0,0,4">
                <TextBlock Text="AssemblyAI (speech-to-text)"
                           FontSize="13" FontWeight="Medium"
                           Foreground="{StaticResource TextSecondary}"
                           VerticalAlignment="Center" />
                <Button Content="Get key &#x2192;"
                        Style="{StaticResource LinkButton}"
                        HorizontalAlignment="Right"
                        Click="AssemblyAiLink_Click" />
            </Grid>
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <PasswordBox x:Name="AssemblyAiKeyBox"
                             Grid.Column="0"
                             Style="{StaticResource DarkPasswordBox}"
                             PasswordChanged="AssemblyAiKeyBox_PasswordChanged"
                             Margin="0,0,8,0" />
                <TextBox x:Name="AssemblyAiSavedPlaceholder"
                         Grid.Column="0"
                         Style="{StaticResource DarkTextBox}"
                         Text="&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;"
                         IsReadOnly="True"
                         Margin="0,0,8,0"
                         Visibility="Collapsed" />
                <Button x:Name="AssemblyAiChangeBtn"
                        Grid.Column="1"
                        Content="Change"
                        Style="{StaticResource TestButton}"
                        Click="AssemblyAiChange_Click"
                        Visibility="Collapsed"
                        Margin="0,0,8,0" />
                <Button x:Name="AssemblyAiTestBtn"
                        Grid.Column="2"
                        Content="Test"
                        Style="{StaticResource TestButton}"
                        Click="AssemblyAiTest_Click" />
            </Grid>

            <!-- AssemblyAI key error -->
            <TextBlock Text="{Binding AssemblyAiKeyError}"
                       FontSize="11" Foreground="{StaticResource Failure}"
                       Margin="0,0,0,4"
                       Visibility="{Binding AssemblyAiKeyError, Converter={StaticResource NullToCollapsed}}" />

            <!-- ElevenLabs API Key -->
            <Grid Margin="0,0,0,4">
                <TextBlock Text="ElevenLabs (text-to-speech)"
                           FontSize="13" FontWeight="Medium"
                           Foreground="{StaticResource TextSecondary}"
                           VerticalAlignment="Center" />
                <Button Content="Get key &#x2192;"
                        Style="{StaticResource LinkButton}"
                        HorizontalAlignment="Right"
                        Click="ElevenLabsLink_Click" />
            </Grid>
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <PasswordBox x:Name="ElevenLabsKeyBox"
                             Grid.Column="0"
                             Style="{StaticResource DarkPasswordBox}"
                             PasswordChanged="ElevenLabsKeyBox_PasswordChanged"
                             Margin="0,0,8,0" />
                <TextBox x:Name="ElevenLabsSavedPlaceholder"
                         Grid.Column="0"
                         Style="{StaticResource DarkTextBox}"
                         Text="&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;"
                         IsReadOnly="True"
                         Margin="0,0,8,0"
                         Visibility="Collapsed" />
                <Button x:Name="ElevenLabsChangeBtn"
                        Grid.Column="1"
                        Content="Change"
                        Style="{StaticResource TestButton}"
                        Click="ElevenLabsChange_Click"
                        Visibility="Collapsed"
                        Margin="0,0,8,0" />
                <Button x:Name="ElevenLabsTestBtn"
                        Grid.Column="2"
                        Content="Test"
                        Style="{StaticResource TestButton}"
                        Click="ElevenLabsTest_Click" />
            </Grid>

            <!-- ElevenLabs key error -->
            <TextBlock Text="{Binding ElevenLabsKeyError}"
                       FontSize="11" Foreground="{StaticResource Failure}"
                       Margin="0,0,0,4"
                       Visibility="{Binding ElevenLabsKeyError, Converter={StaticResource NullToCollapsed}}" />

            <!-- ElevenLabs Voice ID -->
            <TextBlock Text="ELEVENLABS VOICE ID"
                       FontSize="10" FontWeight="SemiBold"
                       Foreground="{StaticResource TextTertiary}"
                       Margin="0,0,0,6" />
            <TextBox Style="{StaticResource DarkTextBox}"
                     Text="{Binding ElevenLabsVoiceId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,20" />

            <!-- Separator -->
            <Border Height="0.5" Background="{StaticResource BorderSubtle}" Margin="0,0,0,16" />

            <!-- Buttons -->
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0"
                        Content="Quit Clicky"
                        Style="{StaticResource SecondaryButton}"
                        Click="Quit_Click" />
                <Button x:Name="SaveButton"
                        Grid.Column="2"
                        Content="Save"
                        Style="{StaticResource AccentButton}"
                        IsEnabled="{Binding CanSave}"
                        Click="Save_Click" />
            </Grid>

            <!-- Help footnote -->
            <TextBlock Text="Your keys are encrypted with your Windows account and stored only on this PC. Clicky never uploads them anywhere."
                       FontSize="11"
                       FontStyle="Italic"
                       Foreground="{StaticResource TextTertiary}"
                       TextWrapping="Wrap"
                       Margin="0,0,0,4" />

        </StackPanel>
    </ScrollViewer>
</Window>

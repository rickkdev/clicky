<Window x:Class="Clicky.App.CompanionPanelWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Clicky"
        Width="320"
        SizeToContent="Height"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        Visibility="Collapsed">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBackground" Color="#1C1C1E" />
        <SolidColorBrush x:Key="BorderSubtle" Color="#2C2C2E" />
        <SolidColorBrush x:Key="TextPrimary" Color="#F5F5F7" />
        <SolidColorBrush x:Key="TextSecondary" Color="#C7C7CC" />
        <SolidColorBrush x:Key="TextTertiary" Color="#8E8E93" />
        <SolidColorBrush x:Key="Success" Color="#34C759" />
        <SolidColorBrush x:Key="Warning" Color="#FF9F0A" />
        <SolidColorBrush x:Key="Accent" Color="#3B82F6" />
    </Window.Resources>

    <Border CornerRadius="12"
            Background="{StaticResource PanelBackground}"
            BorderBrush="{StaticResource BorderSubtle}"
            BorderThickness="0.5"
            Margin="12">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20"
                              ShadowDepth="6"
                              Color="Black"
                              Opacity="0.5" />
        </Border.Effect>

        <StackPanel Margin="0">
            <!-- Header -->
            <Grid Margin="16,14,16,14">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="8" Height="8" Fill="{StaticResource Success}" VerticalAlignment="Center" />
                    <TextBlock Text="Clicky"
                               Margin="8,0,0,0"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimary}"
                               VerticalAlignment="Center" />
                </StackPanel>
                <TextBlock HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           FontSize="12"
                           FontWeight="Medium"
                           Foreground="{StaticResource TextTertiary}"
                           Text="{Binding VoiceStateDisplay}" />
            </Grid>

            <Border Height="0.5" Background="{StaticResource BorderSubtle}" Margin="16,0" />

            <!-- Version + shortcut -->
            <StackPanel Margin="16,14,16,0">
                <TextBlock Text="{Binding AppVersion, StringFormat=Version {0}}"
                           FontSize="11"
                           Foreground="{StaticResource TextTertiary}" />

                <Grid Margin="0,10,0,0">
                    <TextBlock Text="Push-to-talk"
                               FontSize="13"
                               FontWeight="Medium"
                               Foreground="{StaticResource TextSecondary}"
                               VerticalAlignment="Center" />
                    <Border HorizontalAlignment="Right"
                            Background="#262628"
                            CornerRadius="6"
                            BorderBrush="{StaticResource BorderSubtle}"
                            BorderThickness="0.5"
                            Padding="8,3">
                        <TextBlock Text="{Binding PushToTalkShortcutDisplay}"
                                   FontSize="11"
                                   FontWeight="Medium"
                                   Foreground="{StaticResource TextPrimary}" />
                    </Border>
                </Grid>
            </StackPanel>

            <!-- Permissions -->
            <StackPanel Margin="16,14,16,0">
                <TextBlock Text="PERMISSIONS"
                           FontSize="10"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextTertiary}"
                           Margin="0,0,0,6" />

                <!-- Microphone row -->
                <Grid Margin="0,6,0,6">
                    <TextBlock Text="Microphone"
                               FontSize="13"
                               FontWeight="Medium"
                               Foreground="{StaticResource TextSecondary}"
                               VerticalAlignment="Center" />
                    <TextBlock HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               FontSize="11"
                               FontWeight="Medium"
                               Foreground="{StaticResource TextTertiary}"
                               Text="{Binding MicrophonePermissionDisplay}" />
                </Grid>

                <!-- Screen Capture row -->
                <Grid Margin="0,6,0,6">
                    <TextBlock Text="Screen Capture"
                               FontSize="13"
                               FontWeight="Medium"
                               Foreground="{StaticResource TextSecondary}"
                               VerticalAlignment="Center" />
                    <TextBlock HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               FontSize="11"
                               FontWeight="Medium"
                               Foreground="{StaticResource TextTertiary}"
                               Text="{Binding ScreenCapturePermissionDisplay}" />
                </Grid>
            </StackPanel>

            <Border Height="0.5" Background="{StaticResource BorderSubtle}" Margin="16,12,16,0" />

            <!-- Footer -->
            <Grid Margin="16,10,16,14">
                <TextBlock Text="Hold the shortcut to talk."
                           FontSize="11"
                           Foreground="{StaticResource TextTertiary}"
                           VerticalAlignment="Center" />
                <Button x:Name="QuitButton"
                        HorizontalAlignment="Right"
                        Content="Quit Clicky"
                        FontSize="12"
                        Foreground="{StaticResource TextTertiary}"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="6,3"
                        Cursor="Hand"
                        Click="QuitButton_Click" />
            </Grid>
        </StackPanel>
    </Border>
</Window>

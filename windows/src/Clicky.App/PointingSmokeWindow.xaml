<Window x:Class="Clicky.App.PointingSmokeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Clicky Desktop Smoke Test"
        Width="760"
        Height="520"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="#111318"
        Foreground="#F5F7FB"
        Topmost="True">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,14">
            <TextBlock Text="Desktop pointing smoke fixture" FontSize="20" FontWeight="SemiBold" />
            <TextBlock Text="Click a box to run capture, parse, conversion, artifact capture, and live overlay dispatch."
                       Margin="0,6,0,0"
                       Foreground="#BAC3D4" />
        </StackPanel>

        <Grid Grid.Row="1" x:Name="FixtureSurface" Background="#1C212B" ClipToBounds="True">
            <Button x:Name="BoxA"
                    Content="box A"
                    Width="150"
                    Height="90"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Margin="54,44,0,0"
                    Background="#2D7DFA"
                    Foreground="White"
                    FontSize="24"
                    FontWeight="Bold"
                    Click="Box_Click" />
            <Button x:Name="BoxB"
                    Content="box B"
                    Width="180"
                    Height="100"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,72,70,0"
                    Background="#1A9C69"
                    Foreground="White"
                    FontSize="24"
                    FontWeight="Bold"
                    Click="Box_Click" />
            <Button x:Name="BoxC"
                    Content="box C"
                    Width="210"
                    Height="96"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Bottom"
                    Margin="0,0,0,48"
                    Background="#B657D8"
                    Foreground="White"
                    FontSize="24"
                    FontWeight="Bold"
                    Click="Box_Click" />
        </Grid>

        <DockPanel Grid.Row="2" Margin="0,14,0,0">
            <TextBlock x:Name="StatusText"
                       DockPanel.Dock="Left"
                       Foreground="#BAC3D4"
                       VerticalAlignment="Center"
                       Text="Artifacts are written to %APPDATA%\Clicky\point-debug." />
            <Button Content="Close"
                    DockPanel.Dock="Right"
                    Width="96"
                    Height="32"
                    HorizontalAlignment="Right"
                    Click="Close_Click" />
        </DockPanel>
    </Grid>
</Window>

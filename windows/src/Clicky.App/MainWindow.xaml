<Window x:Class="Clicky.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Clicky"
        Width="1040" Height="720"
        MinWidth="860" MinHeight="560"
        WindowStartupLocation="CenterScreen"
        Background="#09090B"
        Foreground="#FAFAFA"
        ShowInTaskbar="True">
    <Window.Resources>
        <SolidColorBrush x:Key="AppBackground" Color="#09090B" />
        <SolidColorBrush x:Key="PanelBackground" Color="#0F1011" />
        <SolidColorBrush x:Key="SurfaceBackground" Color="#18181B" />
        <SolidColorBrush x:Key="RaisedSurface" Color="#1F1F23" />
        <SolidColorBrush x:Key="BorderSubtle" Color="#27272A" />
        <SolidColorBrush x:Key="BorderStrong" Color="#3F3F46" />
        <SolidColorBrush x:Key="TextPrimary" Color="#FAFAFA" />
        <SolidColorBrush x:Key="TextSecondary" Color="#D4D4D8" />
        <SolidColorBrush x:Key="TextTertiary" Color="#A1A1AA" />
        <SolidColorBrush x:Key="Accent" Color="#FAFAFA" />
        <SolidColorBrush x:Key="AccentText" Color="#09090B" />
        <SolidColorBrush x:Key="InputBackground" Color="#09090B" />
        <SolidColorBrush x:Key="Success" Color="#22C55E" />

        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
            <Setter Property="Background" Value="{StaticResource SurfaceBackground}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderSubtle}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{StaticResource RaisedSurface}" />
                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Foreground" Value="{StaticResource AccentText}" />
            <Setter Property="Background" Value="{StaticResource Accent}" />
            <Setter Property="BorderBrush" Value="{StaticResource Accent}" />
        </Style>

        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceBackground}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderSubtle}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="20" />
        </Style>

        <Style x:Key="DarkTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource InputBackground}" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderSubtle}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="CaretBrush" Value="{StaticResource TextPrimary}" />
        </Style>

        <Style x:Key="CodeTextBox" TargetType="TextBox" BasedOn="{StaticResource DarkTextBox}">
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Foreground" Value="{StaticResource TextTertiary}" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder"
                                Background="Transparent"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}"
                                Margin="2">
                            <ContentPresenter ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{StaticResource SurfaceBackground}" />
                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <DockPanel>
                            <Border DockPanel.Dock="Top"
                                    Background="{StaticResource PanelBackground}"
                                    BorderBrush="{StaticResource BorderSubtle}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="4"
                                    HorizontalAlignment="Left"
                                    Margin="0,0,0,18">
                                <TabPanel IsItemsHost="True" />
                            </Border>
                            <ContentPresenter ContentSource="SelectedContent" />
                        </DockPanel>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel Background="{StaticResource AppBackground}">
        <Border DockPanel.Dock="Top" Background="{StaticResource AppBackground}" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="0,0,0,1" Padding="24,16">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="32" Height="32" Background="{StaticResource SurfaceBackground}" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1" CornerRadius="8">
                        <Grid>
                            <Polygon Points="10,7 10,25 24,16" Fill="{StaticResource TextPrimary}" />
                        </Grid>
                    </Border>
                    <StackPanel Margin="12,0,0,0">
                        <TextBlock Text="Clicky" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" />
                        <TextBlock Text="Local voice companion" FontSize="12" Foreground="{StaticResource TextTertiary}" Margin="0,2,0,0" />
                    </StackPanel>
                    <Border Background="#052E16" BorderBrush="#14532D" BorderThickness="1" CornerRadius="999" Padding="9,3" Margin="16,0,0,0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="6" Height="6" Fill="{StaticResource Success}" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding VoiceStateDisplay}" FontSize="12" Foreground="#BBF7D0" Margin="7,0,0,0" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Settings" Style="{StaticResource ActionButton}" Margin="0,0,8,0" Click="SettingsButton_Click" />
                    <Button Content="Quit" Style="{StaticResource PrimaryButton}" Click="QuitButton_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <TabControl Background="{StaticResource AppBackground}" BorderThickness="0" Margin="24">
            <TabItem Header="Overview">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource CardBorder}" Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="Runtime" FontSize="17" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" />
                            <TextBlock Text="Current model, permissions, and voice shortcut." FontSize="13" Foreground="{StaticResource TextTertiary}" Margin="0,5,0,18" />

                            <Border Height="1" Background="{StaticResource BorderSubtle}" Margin="0,0,0,14" />

                            <Grid Margin="0,0,0,12">
                                <TextBlock Text="Model" Foreground="{StaticResource TextTertiary}" />
                                <TextBlock Text="{Binding LlmModelDisplay}" Foreground="{StaticResource TextPrimary}" FontWeight="Medium" HorizontalAlignment="Right" />
                            </Grid>
                            <Grid Margin="0,0,0,12">
                                <TextBlock Text="Push-to-talk" Foreground="{StaticResource TextTertiary}" />
                                <TextBlock Text="{Binding PushToTalkShortcutDisplay}" Foreground="{StaticResource TextPrimary}" FontWeight="Medium" HorizontalAlignment="Right" />
                            </Grid>
                            <Grid Margin="0,0,0,12">
                                <TextBlock Text="Microphone" Foreground="{StaticResource TextTertiary}" />
                                <TextBlock Text="{Binding MicrophonePermissionDisplay}" Foreground="{StaticResource TextPrimary}" FontWeight="Medium" HorizontalAlignment="Right" />
                            </Grid>
                            <Grid>
                                <TextBlock Text="Screen capture" Foreground="{StaticResource TextTertiary}" />
                                <TextBlock Text="{Binding ScreenCapturePermissionDisplay}" Foreground="{StaticResource TextPrimary}" FontWeight="Medium" HorizontalAlignment="Right" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource CardBorder}" Margin="10,0,0,0">
                        <StackPanel>
                            <TextBlock Text="Knowledge Store" FontSize="17" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" />
                            <TextBlock Text="Markdown and text files appended to each turn." FontSize="13" Foreground="{StaticResource TextTertiary}" Margin="0,5,0,18" />
                            <TextBlock Text="Local folder" FontSize="12" FontWeight="Medium" Foreground="{StaticResource TextTertiary}" Margin="0,0,0,6" />
                            <TextBox x:Name="KnowledgePathBox" Style="{StaticResource DarkTextBox}" IsReadOnly="True" TextWrapping="Wrap" Margin="0,0,0,14" Foreground="{StaticResource TextSecondary}" />
                            <TextBlock x:Name="KnowledgeSummaryText" Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Master Prompt">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Margin="0,0,0,14">
                        <TextBlock Text="Master Prompt" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" />
                        <TextBlock Text="The base prompt Clicky sends before adding local knowledge files." Foreground="{StaticResource TextTertiary}" Margin="0,4,0,0" />
                    </StackPanel>
                    <TextBox x:Name="MasterPromptBox" Grid.Row="1" Style="{StaticResource CodeTextBox}" IsReadOnly="True" AcceptsReturn="True" AcceptsTab="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" />
                </Grid>
            </TabItem>

            <TabItem Header="Knowledge">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="320" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <DockPanel Grid.Column="0" Margin="0,0,14,0">
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10">
                            <Button Content="Add File" Style="{StaticResource PrimaryButton}" Margin="0,0,8,0" Click="AddKnowledgeFile_Click" />
                            <Button Content="Folder" Style="{StaticResource ActionButton}" Click="OpenKnowledgeFolder_Click" />
                        </StackPanel>
                        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,10,0,0">
                            <Button Content="Refresh" Style="{StaticResource ActionButton}" Margin="0,0,8,0" Click="RefreshKnowledge_Click" />
                            <Button Content="Remove" Style="{StaticResource ActionButton}" Click="RemoveKnowledgeFile_Click" />
                        </StackPanel>
                        <ListBox x:Name="KnowledgeFilesList" Background="{StaticResource SurfaceBackground}" Foreground="{StaticResource TextPrimary}" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1" Padding="4" SelectionChanged="KnowledgeFilesList_SelectionChanged" DisplayMemberPath="Name" />
                    </DockPanel>

                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock x:Name="SelectedKnowledgeTitle" Text="Select a knowledge file" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,10" />
                        <TextBox x:Name="KnowledgePreviewBox" Grid.Row="1" Style="{StaticResource CodeTextBox}" IsReadOnly="True" AcceptsReturn="True" AcceptsTab="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" />
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
